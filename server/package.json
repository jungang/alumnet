{
  "name": "server",
  "version": "1.0.0",
  "description": "校友查询系统后端服务",
  "main": "dist/app.js",
  "scripts": {
    "dev": "tsx watch src/app.ts",
    "build": "tsc",
    "start": "node dist/app.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "db:migrate": "node-pg-migrate --config dbconfig.js up",
    "db:rollback": "node-pg-migrate --config dbconfig.js down",
    "db:create-migration": "node-pg-migrate --config dbconfig.js create"
  },
  "dependencies": {
    "@qdrant/js-client-rest": "^1.16.2",
    "@types/archiver": "^7.0.0",
    "@types/tar": "^7.0.87",
    "archiver": "^7.0.1",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.5.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.11.3",
    "pgvector": "^0.1.8",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "tar": "^7.5.9",
    "uuid": "^9.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@anatine/zod-openapi": "^2.2.8",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/helmet": "^4.0.0",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/multer": "^1.4.11",
    "@types/node": "^25.7.0",
    "@types/pg": "^8.10.9",
    "@types/supertest": "^7.2.0",
    "@types/swagger-jsdoc": "^6.0.0",
    "@types/swagger-ui-express": "^4.1.0",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "@vitest/coverage-v8": "^4.1.6",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "fast-check": "^4.7.0",
    "node-pg-migrate": "^8.0.4",
    "prettier": "^3.0.0",
    "supertest": "^7.2.2",
    "tsx": "^4.7.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
