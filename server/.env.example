# 数据库配置
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=your_database_name
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_SSL=false
# DB_SSL=true 时是否验证证书（默认 true，仅开发环境可设 false）
# DB_SSL_REJECT_UNAUTHORIZED=false
# DB_SSL_CA_PATH=/path/to/ca-cert.pem

# JWT配置
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=7d

# CORS 配置（逗号分隔允许的前端域名）
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# AI服务配置 - GLM-4
GLM_API_KEY=your_glm_api_key_here
GLM_BASE_URL=https://open.bigmodel.cn/api/coding/paas/v4

# AI服务配置 - DeepSeek (备选)
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com

# AI服务选择: glm 或 deepseek
AI_PROVIDER=glm

# Embedding服务配置
EMBEDDING_PROVIDER=bge
EMBEDDING_BASE_URL=http://localhost:55555
EMBEDDING_MODEL=bge-m3

# Qdrant向量数据库配置
QDRANT_URL=http://127.0.0.1:6333
QDRANT_API_KEY=your_qdrant_api_key_here
QDRANT_COLLECTION=alumni_knowledge

# RAG 配置
# RAG 查询最大输入长度（字符）
RAG_MAX_INPUT_LENGTH=500
# RAG 每日 token 消费上限（0=不限制）
RAG_DAILY_TOKEN_BUDGET=0
# RAG 单次查询超时（毫秒）
RAG_QUERY_TIMEOUT_MS=30000

# 服务器配置
PORT=3000
NODE_ENV=production
UPLOAD_DIR=/app/server/uploads

# 学校/机构配置 (可自定义)
SCHOOL_NAME=示例中学
SCHOOL_LOGO_URL=/logo.png
SCHOOL_SINCE=1917

# 触控屏配置
SCREEN_RESOLUTION=1920x1080
